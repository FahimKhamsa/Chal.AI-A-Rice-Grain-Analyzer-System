# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=production          # set to "production" to disable Swagger UI
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Security ───────────────────────────────────────────────────────────────────
# A strong random secret for API key auth. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=replace-with-strong-random-secret

# Comma-separated list of allowed CORS origins (no trailing slash, no wildcards)
CORS_ALLOWED_ORIGINS=https://your-flutter-app.com,https://chalai.com

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
SUPABASE_RESULTS_BUCKET=analysis-results

# ── RunPod ────────────────────────────────────────────────────────────────────
RUNPOD_API_KEY=your-runpod-api-key
